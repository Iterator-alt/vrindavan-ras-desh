// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN") // SUPERADMIN, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
  orders    Order[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  published Boolean  @default(false)
  slug      String   @unique @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id             String @id @default("default")
  contactEmail   String?
  contactPhone   String?
  instagramUrl   String?
  youtubeUrl     String?
  heroTitle      String?
  heroSubtitle   String?
  heroImageUrl   String?
  heroImageUrl2  String?
  heroImageUrl3  String?
  heroImageUrl4  String?
  heroImages     String[]  @default([])
  aboutImages    String[]  @default([])
  videoUrl1      String?
  videoTitle1    String?
  videoUrl2      String?
  videoTitle2    String?
  videoUrl3      String?
  videoTitle3    String?
  instagramPost1 String?
  instagramPost2 String?
  instagramPost3 String?
  facebookUrl    String?
  // Payment QR Code Settings
  paymentQRCode  String?   // URL to uploaded QR code image
  upiId          String?   // UPI ID for display (optional)
  paymentInstructions String? // Custom payment instructions

  // Live Darshan Settings
  liveDarshanUrl    String?   // YouTube live stream URL
  liveDarshanActive Boolean   @default(false)

  // Contact Page Settings
  address           String?
  mapEmbedUrl       String?   // Google Maps embed URL
}


model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String?
  imageUrl    String?
  link        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Donation/Seva Settings
model DonationSettings {
  id                String   @id @default("default")
  donationPageUrl   String?  // External domain URL for production redirect
  sewaOptions       Json     @default("[]") // Array of seva boxes
  pageTitle         String   @default("Support Our Seva")
  pageSubtitle      String   @default("Contribute to the divine service")
  pageDescription   String?
  heroImage         String?
  isEnabled         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// E-Commerce Models

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String
  price          Float
  compareAtPrice Float?      // Original price for showing discounts
  images         String[]    // Array of image URLs
  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id])
  stock          Int         @default(0)
  isActive       Boolean     @default(true)
  featured       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String?
  user              User?       @relation(fields: [userId], references: [id])
  customerName      String
  customerEmail     String
  customerPhone     String
  shippingAddress   String
  shippingCity      String
  shippingState     String
  shippingPincode   String
  status            String      @default("pending") // pending, confirmed, processing, shipped, delivered, cancelled
  subtotal          Float
  tax               Float
  shipping          Float
  total             Float
  paymentMethod     String?     // razorpay, cod
  paymentStatus     String      @default("pending") // pending, success, failed
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  items             OrderItem[]
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Price at time of order
  total     Float
}

// Gallery for photos
model GalleryImage {
  id          String   @id @default(cuid())
  title       String?
  description String?
  imageUrl    String
  category    String   @default("general") // general, darshan, events, festivals
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Videos from YouTube
model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  youtubeUrl  String   // Full YouTube URL or embed URL
  thumbnailUrl String?
  category    String   @default("general") // bhajan, discourse, kirtan, darshan, festival
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Schedule/Aarti Timings
model ScheduleItem {
  id          String   @id @default(cuid())
  title       String   // e.g., "Mangala Aarti"
  description String?
  time        String   // e.g., "4:30 AM"
  day         String   @default("daily") // daily, monday, tuesday, etc., or special
  category    String   @default("aarti") // aarti, darshan, bhog, special
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Donation Records
model Donation {
  id              String   @id @default(cuid())
  donationNumber  String   @unique
  donorName       String
  donorPhone      String
  donorEmail      String?
  sevaTitle       String
  sevaId          String?
  amount          Float
  transactionId   String?
  paymentStatus   String   @default("pending") // pending, verified, failed
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Contact Form Submissions
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
